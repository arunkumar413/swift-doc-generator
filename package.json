{
  "name": "swift-doc-generator",
  "displayName": "Swift Markdown Documentation Generator",
  "description": "Generate Markdown documentation from Swift multiline comments.",
  "version": "0.1.0",
  "publisher": "swift-doc-generator",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:swiftDoc.generateMarkdown"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "clean": "rimraf dist coverage",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "test": "jest --coverage",
    "package": "vsce package --no-dependencies --allow-missing-repository",
    "vscode:prepublish": "npm run compile"
  },
  "contributes": {
    "commands": [
      {
        "command": "swiftDoc.generateMarkdown",
        "title": "Generate Markdown",
        "category": "Swift Docs"
      },
      {
        "command": "swiftDoc.generateMarkdownFromContext",
        "title": "Generate Markdown Documentation",
        "category": "Swift Docs"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "swiftDoc.generateMarkdownFromContext",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "command": "swiftDoc.generateMarkdownFromContext",
          "when": "resourceExtname == .swift",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "swiftDoc.generateMarkdownFromContext",
          "when": "editorLangId == swift",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Swift Docs",
      "properties": {
        "swiftDoc.outputFolder": {
          "type": "string",
          "default": "",
          "description": "Optional output folder for generated Markdown. Leave empty to write next to the Swift source file."
        },
        "swiftDoc.overwrite": {
          "type": "boolean",
          "default": false,
          "description": "Overwrite existing Markdown files without asking for confirmation."
        },
        "swiftDoc.openAfterGenerate": {
          "type": "boolean",
          "default": true,
          "description": "Open the generated Markdown file after generation."
        },
        "swiftDoc.includeImports": {
          "type": "boolean",
          "default": true,
          "description": "Include Swift import statements in generated code fences."
        },
        "swiftDoc.codeFenceLanguage": {
          "type": "string",
          "default": "swift",
          "description": "Language identifier used for generated Markdown code fences."
        }
      }
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.3",
    "typescript": "^5.5.3"
  }
}
